{
  "name": "dcf-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "bun test",
    "test:e2e:install": "playwright install",
    "test:e2e": "PLAYWRIGHT_PORT=3101 playwright test --project=chromium",
    "test:e2e:mobile": "PLAYWRIGHT_PORT=3101 playwright test --project=mobile-chromium",
    "test:e2e:iphone": "PLAYWRIGHT_PORT=3101 playwright test --project=iphone-15-pro-max",
    "test:e2e:iphone:update-visual": "PLAYWRIGHT_PORT=3101 playwright test --project=iphone-15-pro-max --update-snapshots=all e2e/visual.pw.ts",
    "test:e2e:ui": "PLAYWRIGHT_PORT=3101 PLAYWRIGHT_WEB_SERVER_MODE=dev playwright test --ui --ui-host=0.0.0.0 --ui-port=9323 --workers=1",
    "test:e2e:headed": "PLAYWRIGHT_PORT=3101 PLAYWRIGHT_WEB_SERVER_MODE=dev node scripts/with_display.cjs -- playwright test --headed --workers=1",
    "test:e2e:qa": "PLAYWRIGHT_PORT=3101 PLAYWRIGHT_WEB_SERVER_MODE=dev PLAYWRIGHT_SLOWMO=150 node scripts/with_display.cjs -- playwright test --headed --workers=1"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "clsx": "^2.1.1",
    "convex": "^1.31.2",
    "next": "^15.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "bun-types": "^1.3.9",
    "convex-test": "^0.0.41",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
