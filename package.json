{
  "name": "dcf-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=768 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test --test-concurrency=1 --experimental-transform-types test/*.test.ts",
    "test:routes": "bun test ./convex_tests/routeImports.bun.test.ts",
    "test:convex": "bun test convex_tests/*.test.ts",
    "test:ci": "bun run test && bun run test:convex && bun run test:routes",
    "typecheck:convex": "bunx convex typecheck",
    "debug:timeline": "node run_debug_timeline.js",
    "debug:failures": "node run_debug_failures.js"
  },
  "dependencies": {
    "convex": "^1.31.2",
    "next": "^14.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.9.3"
  }
}
