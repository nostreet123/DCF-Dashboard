# Copy to .env.local and fill in secrets. Do not commit secrets.
CONVEX_DEPLOY_KEY=
CONVEX_DEPLOYMENT=
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
DAMODARAN_SYNC_TOKEN=
TABLEDATA_INSERT_MAX_ROWS=
DAMODARAN_INSERT_BATCH_MAX_ROWS=
DAMODARAN_INSERT_BATCH_MAX_BYTES=
DAMODARAN_RATE_LIMIT_SECONDS=
DAMODARAN_MIRROR_MANIFEST_URL=
DAMODARAN_FAST_EXIT_IF_MANIFEST_UNCHANGED=
DAMODARAN_SNAPSHOT_BATCH_SIZE=
DAMODARAN_SYNC_WORKERS=
# Conditional GET optimization (enabled by default, set to 0 to disable)
DAMODARAN_CONDITIONAL_GET=

# FastAPI DCF engine base URL (e.g. http://localhost:8000)
DCF_ENGINE_URL=
# Shared HMAC secret for Next.js -> FastAPI internal requests.
DCF_ENGINE_INTERNAL_KEY=
# Next.js API rate-limit client identity source:
#   vercel (default): trust x-vercel-forwarded-for only
#   legacy: trust cf-connecting-ip / x-real-ip
#   compat: legacy + optional x-forwarded-for fallback when RATE_LIMIT_IDENTITY_MODE=compat
RATE_LIMIT_IDENTITY_SOURCE=
# x-forwarded-for fallback behavior for RATE_LIMIT_IDENTITY_SOURCE=compat:
#   strict (default): do not use x-forwarded-for
#   compat: allow x-forwarded-for fallback
RATE_LIMIT_IDENTITY_MODE=
# Internal key for mutation-capable Next.js routes. Send in `x-dcf-internal-key`.
INTERNAL_PERSISTENCE_KEY=

# SEC EDGAR integration user agent; format: "YourName your@email.com"
# or "CompanyName contact@example.com"
SEC_USER_AGENT=
# FastAPI docs are disabled by default. Set to 1 for local/dev only.
DCF_ENGINE_EXPOSE_DOCS=

# FastAPI /dcf/compute trusted proxy controls:
#   DCF_TRUSTED_PROXY_MODE=off (default) uses socket client IP only.
#   DCF_TRUSTED_PROXY_MODE=allowlist enables x-forwarded-for ONLY when the
#   request peer IP is within DCF_TRUSTED_PROXY_CIDRS.
DCF_TRUSTED_PROXY_MODE=
DCF_TRUSTED_PROXY_CIDRS=

# Monte Carlo (optional)
# Enable correlated sampling in the DCF engine:
#   MONTE_CARLO_DEPENDENCE=oneFactor
#   MONTE_CARLO_ONE_FACTOR_LOADING=0.8
MONTE_CARLO_DEPENDENCE=
MONTE_CARLO_ONE_FACTOR_LOADING=
