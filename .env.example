#
# Copy to .env.local for local use. Leave real values out of git, PRs, docs, and screenshots.
#

# Public-safe client config
# Safe to expose in browser bundles when the frontend needs direct Convex reads.
NEXT_PUBLIC_CONVEX_URL=
# Defaults to live EDGAR-backed mode when unset. Set to demo only when the
# browser dashboard should use mock data without service configuration.
NEXT_PUBLIC_DCF_DASHBOARD_MODE=
# Set to 1 only when VALUATION_HISTORY_BROWSER_READS is also enabled server-side.
NEXT_PUBLIC_VALUATION_HISTORY_BROWSER_READS=

# Private server-side infrastructure details
# Treat these as operationally sensitive even if some are not secret values.
CONVEX_URL=
CONVEX_DEPLOYMENT=
DCF_ENGINE_URL=
SEC_USER_AGENT=
DCF_TRUSTED_PROXY_CIDRS=
# Enables browser-readable valuation history routes. Leave unset unless saved
# valuation runs are safe to expose to authenticated/allowed browser users.
VALUATION_HISTORY_BROWSER_READS=
# Optional browser import-context reads. Leave unset in public demos unless the
# caller also supplies x-import-context-token matching this SHA-256 digest.
IMPORT_CONTEXT_BROWSER_TOKEN_SHA256=

# Server-only secrets: never expose
CONVEX_DEPLOY_KEY=
DAMODARAN_SYNC_TOKEN=
HUGGING_FACE_API_KEY=
HUGGING_FACE_MODEL=deepseek-ai/DeepSeek-V4-Pro:fastest
HUGGING_FACE_REASONING_EFFORT=xhigh
HUGGING_FACE_RESPONSE_FORMAT=json_object
HUGGING_FACE_MAX_INPUT_BYTES=4000000
HUGGING_FACE_MAX_OUTPUT_TOKENS=8192
HUGGING_FACE_PROVIDER_TIMEOUT_MS=90000
HUGGING_FACE_TEMPERATURE=1
HUGGING_FACE_TOP_P=1
# Optional public-demo admin bypass for AI demo caps. Store only a SHA-256 hex
# digest of the admin token, never the raw token. Example:
#   printf %s 'your-long-admin-token' | shasum -a 256
DCF_DEMO_ADMIN_TOKEN_SHA256=
# Shared HMAC secret for Next.js -> FastAPI internal requests.
# Keep this different from INTERNAL_PERSISTENCE_KEY.
DCF_ENGINE_INTERNAL_KEY=
# Shared HMAC secret for privileged inbound requests to Next.js persistence routes.
# Requests are signed with x-dcf-internal-signature, x-dcf-internal-ts, and
# x-dcf-internal-nonce headers.
INTERNAL_PERSISTENCE_KEY=
# Local/demo browser import approval. Keep disabled in public deployments unless
# a real app session/auth layer gates this route. When enabled, callers must send
# x-import-approval-token whose SHA-256 hex digest matches this value.
IMPORT_APPROVAL_BROWSER_WRITES=
IMPORT_APPROVAL_BROWSER_TOKEN_SHA256=

# Local-only unsafe opt-out
# Set to 1 only for trusted local/dev runs when you intentionally want FastAPI
# to accept unsigned requests and bypass Convex-backed shared security state.
# Leave unset everywhere public, shared, or hosted.
DCF_ENGINE_ALLOW_UNSIGNED=
# Set to 1 only for single-process private/dev FastAPI runs without Convex-backed
# replay protection. Leave unset in hosted or horizontally scaled environments.
DCF_ENGINE_ALLOW_PROCESS_LOCAL_NONCES=

# Sync and ingestion tuning (non-secret)
TABLEDATA_INSERT_MAX_ROWS=
DAMODARAN_INSERT_BATCH_MAX_ROWS=
DAMODARAN_INSERT_BATCH_MAX_BYTES=
DAMODARAN_RATE_LIMIT_SECONDS=
DAMODARAN_MIRROR_MANIFEST_URL=
DAMODARAN_ALLOWED_ASSET_HOSTS=
DAMODARAN_DOWNLOAD_MAX_BYTES=
DAMODARAN_MIRROR_MANIFEST_MAX_BYTES=
DAMODARAN_EXCEL_MAX_FILE_BYTES=
DAMODARAN_EXCEL_MAX_SHEETS=
DAMODARAN_EXCEL_MAX_ROWS=
DAMODARAN_EXCEL_MAX_COLUMNS=
DAMODARAN_FAST_EXIT_IF_MANIFEST_UNCHANGED=
DAMODARAN_SNAPSHOT_BATCH_SIZE=
DAMODARAN_SYNC_WORKERS=

# Conditional GET optimization (enabled by default, set to 0 to disable)
DAMODARAN_CONDITIONAL_GET=

# Next.js API rate-limit client identity source:
#   vercel (default): trust x-vercel-forwarded-for only
#   legacy/compat: trust cf-connecting-ip / x-real-ip only
# Generic x-forwarded-for is never trusted for public API rate limits because
# many proxies append to caller-supplied values instead of overwriting them.
RATE_LIMIT_IDENTITY_SOURCE=
# Local-only escape hatch for dev servers that do not expose NODE_ENV=development
# to route handlers. Never set this in hosted/public deployments.
DCF_RATE_LIMIT_ALLOW_LOCALHOST=

# Public-demo AI cost controls. Admin mode bypasses these caps.
API_RATE_LIMIT_AI_SCENARIO_PER_MINUTE=
API_RATE_LIMIT_AI_SCENARIO_DAILY=

# FastAPI docs are disabled by default. Set to 1 for local/dev only.
DCF_ENGINE_EXPOSE_DOCS=

# FastAPI /dcf/compute trusted proxy controls:
#   DCF_TRUSTED_PROXY_MODE=off (default) uses socket client IP only.
#   DCF_TRUSTED_PROXY_MODE=allowlist enables x-forwarded-for ONLY when the
#   request peer IP is within DCF_TRUSTED_PROXY_CIDRS.
# Signed FastAPI mode also requires CONVEX_URL and DAMODARAN_SYNC_TOKEN so
# replay protection and compute rate limiting can use shared Convex state.
DCF_TRUSTED_PROXY_MODE=

# Monte Carlo (optional)
# Enable correlated sampling in the DCF engine:
#   MONTE_CARLO_DEPENDENCE=oneFactor
#   MONTE_CARLO_ONE_FACTOR_LOADING=0.8
MONTE_CARLO_DEPENDENCE=
MONTE_CARLO_ONE_FACTOR_LOADING=
