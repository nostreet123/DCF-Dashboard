# Copy to .env.local and fill in secrets. Do not commit secrets.
CONVEX_DEPLOY_KEY=
CONVEX_DEPLOYMENT=
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
DAMODARAN_SYNC_TOKEN=
TABLEDATA_INSERT_MAX_ROWS=
DAMODARAN_INSERT_BATCH_MAX_ROWS=
DAMODARAN_INSERT_BATCH_MAX_BYTES=
DAMODARAN_RATE_LIMIT_SECONDS=
DAMODARAN_MIRROR_MANIFEST_URL=
DAMODARAN_FAST_EXIT_IF_MANIFEST_UNCHANGED=
DAMODARAN_SNAPSHOT_BATCH_SIZE=
DAMODARAN_SYNC_WORKERS=
# Conditional GET optimization (enabled by default, set to 0 to disable)
DAMODARAN_CONDITIONAL_GET=

# FastAPI DCF engine base URL (e.g. http://localhost:8000)
DCF_ENGINE_URL=

# SEC EDGAR integration user agent; format: "YourName your@email.com"
# or "CompanyName contact@example.com"
SEC_USER_AGENT=

# Monte Carlo (optional)
# Enable correlated sampling in the DCF engine:
#   MONTE_CARLO_DEPENDENCE=oneFactor
#   MONTE_CARLO_ONE_FACTOR_LOADING=0.8
MONTE_CARLO_DEPENDENCE=
MONTE_CARLO_ONE_FACTOR_LOADING=
