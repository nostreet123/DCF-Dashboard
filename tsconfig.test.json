{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "bun-types"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "e2e/**/*.ts",
    "convex_tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".venv",
    "python",
    "scripts",
    "playwright-report",
    "test-results",
    "run_asset_backfill.js"
  ]
}
